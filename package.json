{
  "name": "@outloud/adonis-scheduler",
  "type": "module",
  "version": "1.0.7",
  "description": "Schedule cron jobs in AdonisJS 6/7.",
  "author": "Outloud <hello@outloud.co>",
  "contributors": [
    "Andrej Adamcik"
  ],
  "license": "MIT",
  "homepage": "https://github.com/madebyoutloud/adonis-scheduler#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madebyoutloud/adonis-scheduler.git"
  },
  "files": [
    "build"
  ],
  "exports": {
    ".": "./build/src/index.js",
    "./provider": "./build/providers/scheduler.provider.js",
    "./commands": "./build/commands/main.js",
    "./service": "./build/services/main.js",
    "./services/*": "./build/services/*.js"
  },
  "sideEffects": false,
  "scripts": {
    "copy:templates": "copyfiles \"stubs/**/*.stub\" build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . ",
    "lint:fix": "eslint --fix .",
    "quick:test": "node --import=./tsnode.esm.js --enable-source-maps bin/test.ts",
    "pretest": "pnpm run lint",
    "test": "c8 pnpm run quick:test",
    "build": "tsdown && pnpm run copy:templates && pnpm run index:commands",
    "release": "release-it",
    "index:commands": "NODE_OPTIONS='--import=reflect-metadata' adonis-kit index build/commands"
  },
  "peerDependencies": {
    "@adonisjs/core": "^6 || ^7",
    "@adonisjs/lock": "^1 || ^2"
  },
  "peerDependenciesMeta": {
    "@adonisjs/lock": {
      "optional": true
    }
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/core": "~7.0.0",
    "@adonisjs/lock": "^2.1.0",
    "@adonisjs/tsconfig": "^1.4.1",
    "@outloud/eslint-config": "^2.1.3",
    "@swc/core": "^1.13.3",
    "@types/node": "^24.2.1",
    "copyfiles": "^2.4.1",
    "eslint": "^9.33.0",
    "reflect-metadata": "^0.2.2",
    "release-it": "^19.0.4",
    "tsdown": "0.21.0-beta.2",
    "tsup": "~8.5.0",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "croner": "^9"
  }
}
